# GitHub OAuth App (https://github.com/settings/developers)
# Copy to ".env" in the project root and fill in. ".env" is gitignored.
GITFINDER_GITHUB_CLIENT_ID=
GITFINDER_GITHUB_CLIENT_SECRET=

# Optional: must match the callback URL in your OAuth app: http://127.0.0.1:<port>/callback
# GITFINDER_OAUTH_PORT=53682
