{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["api/**/*.ts", "src/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", ".vercel", "src/main", "src/preload", "src/renderer"]
}
